# FreeSystemDoctor — Caddy config for Railway
# Railway terminates TLS at the edge and forwards plain HTTP on $PORT.

{
	# Don't try to provision certs ourselves
	auto_https off
	# Don't expose Caddy's admin API
	admin off
	# Quieter logs (Railway log volume can get expensive)
	log {
		output stdout
		format console
		level INFO
	}
}

:{$PORT:8080} {
	root * /usr/share/caddy

	encode gzip zstd

	# Eat-your-own-dog-food security headers
	header {
		# Trust the edge TLS — long HSTS is safe once a stable custom domain is set
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "geolocation=(), camera=(), microphone=(), payment=()"
		# We deliberately do NOT set a strict CSP here — the AI Risk Analyst
		# lets users point to a custom OpenAI-compatible endpoint, which would
		# break under a locked-down connect-src. If you want CSP, tune it for
		# your specific BYOK provider list.
		-Server
	}

	# Tighter caching for the executable; short cache for HTML so deploys roll out fast
	@assets {
		path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2
	}
	header @assets Cache-Control "public, max-age=86400"

	@html {
		path *.html /
	}
	header @html Cache-Control "public, max-age=300, must-revalidate"

	@exe path *.exe
	header @exe {
		Cache-Control "public, max-age=3600"
		Content-Disposition "attachment"
	}

	file_server {
		index index.html
	}

	# Friendly 404 — serve index.html so users land on the home page, not a Caddy
	# default page. Removes the need for a custom 404.html.
	handle_errors {
		@404 expression {http.error.status_code} == 404
		rewrite @404 /index.html
		file_server
	}
}
